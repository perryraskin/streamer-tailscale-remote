# Copy this file to google/.env on the host that runs FamilyTV.
# Do not commit google/.env; it contains your tailnet-specific hostnames.

# Required: paired Google TV ADB target. Prefer the TV's Tailscale MagicDNS name
# when the TV is on your tailnet.
# Example shape: GOOGLE_TV_ADDR=<tv-name>.<tailnet>.ts.net:<adb-connect-port>
GOOGLE_TV_ADDR=

# FamilyTV HTTP server port on the host.
PORT=3000

# Tailscale HTTPS port used by scripts/start-familytv.sh --serve.
# Use 8443 when 443 is already occupied on the host.
TAILSCALE_SERVE_PORT=8443

# Optional: driver and HDMI/live-view stream.
DRIVER=google-tv
STREAM_URL=

# Optional: AI/tool-runner base URL. This is the FamilyTV host URL, not the TV.
# Example shape: FAMILYTV_BASE_URL=https://<familytv-host>.<tailnet>.ts.net:8443
FAMILYTV_BASE_URL=
